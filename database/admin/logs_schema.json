{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SystemLog",
  "type": "object",
  "required": ["timestamp", "level", "message"],
  "properties": {
    "timestamp": {"type": "string", "format": "date-time"},
    "level": {"type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]},
    "message": {"type": "string"},
    "metadata": {"type": "object"}
  }
}
